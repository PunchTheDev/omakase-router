{
  "$comment": "The single fenced JSON block every OC-R PR body must contain. Everything else in the body is decoration with zero authority.",
  "type": "object",
  "required": ["competition", "hotkey", "github_login", "weights_sha256", "self_score", "signature"],
  "additionalProperties": false,
  "properties": {
    "competition": {"const": "omakase-router"},
    "hotkey": {"type": "string", "minLength": 46, "maxLength": 50},
    "github_login": {"type": "string"},
    "weights_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "self_score": {
      "type": "object",
      "required": ["accuracy", "split", "seed"],
      "properties": {
        "accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "split": {"type": "string"},
        "seed": {"type": "integer"}
      }
    },
    "decryption_key_enc": {
      "type": "string",
      "$comment": "Production: submission key encrypted to the maintainer pubkey. Absent in dev mode."
    },
    "signature": {"type": "string", "$comment": "Hotkey signature over sha256(competition|hotkey|weights_sha256)."}
  }
}
